{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Contract Triage",
  "version": "0.1.0",
  "identifier": "com.example.contracttriage",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Contract Triage",
        "width": 1180,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
